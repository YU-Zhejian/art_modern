#ifndef ART_MODERN_CONFIG_H
#define ART_MODERN_CONFIG_H

// Names and versions

#cmakedefine USED_HTSLIB_NAME "${USED_HTSLIB_NAME}"
#cmakedefine USED_LIBFMT_NAME "${USED_LIBFMT_NAME}"
#cmakedefine ART_MODERN_VERSION "${ART_MODERN_VERSION}"
#cmakedefine ART_MODERN_LINK_LIBS "${ART_MODERN_LINK_LIBS}"
#cmakedefine ART_MODERN_URL "${ART_MODERN_URL}"

// Random Generators

#cmakedefine USE_STL_RANDOM
#cmakedefine USE_PCG_RANDOM
#cmakedefine USE_BOOST_RANDOM
#cmakedefine USE_ONEMKL_RANDOM
#cmakedefine USE_SYSTEM_PCG_RANDOM

// Library availability

#cmakedefine WITH_BOOST_TIMER
#cmakedefine WITH_MPI
#cmakedefine WITH_ONEMKL
#cmakedefine WITH_BOOST_STACKTRACE
#cmakedefine WITH_SYSTEM_PCG
#cmakedefine WITH_LIBDEFLATE

// Debug
#cmakedefine CEU_CM_IS_DEBUG
#cmakedefine USE_ASIO_PARALLEL
#cmakedefine USE_BS_PARALLEL
#cmakedefine USE_NOP_PARALLEL

// Malloc
#cmakedefine WITH_MIMALLOC
#cmakedefine WITH_JEMALLOC
#cmakedefine WITH_TCMALLOC

// Git
#cmakedefine WITH_GIT
#cmakedefine CEU_CM_GIT_COMMIT_HASH "${CEU_CM_GIT_COMMIT_HASH}"
#cmakedefine CEU_CM_GIT_COMMIT_DATE "${CEU_CM_GIT_COMMIT_DATE}"
#cmakedefine CEU_CM_GIT_COMMIT_MESSAGE "${CEU_CM_GIT_COMMIT_MESSAGE}"

// Reverse
#cmakedefine AM_NO_Q_REVERSE

#cmakedefine WITH_NCBI_NGS
#endif
